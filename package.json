{
  "name": "keel",
  "version": "0.1.0",
  "private": true,
  "description": "Keel BaaS - Backend as a Service platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "node packages/db/src/runner.js",
    "db:migrate:init": "node packages/db/src/init.js",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  }
}
