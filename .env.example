# Keel Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://keel:keel_dev@localhost:5432/keel_master
DB_PASSWORD=keel_dev

# JWT
JWT_SECRET=your-secret-key-change-in-production-min-32-chars

# Admin dashboard login (replaces OAuth)
ADMIN_EMAIL=admin@keel.dev
ADMIN_PASSWORD=your-admin-password-change-me

# Encryption key for per-project OAuth + R2 configs (32+ chars recommended)
ENCRYPTION_KEY=your-encryption-key-at-least-32-characters-change-me

# Application
BASE_URL=http://localhost
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
VITE_GATEWAY_URL=http://localhost/v1
VITE_WS_URL=ws://localhost/ws
